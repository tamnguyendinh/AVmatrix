{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/avmatrix-hook.js",
            "timeout": 10,
            "statusMessage": "Enriching with AVmatrix graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/avmatrix-hook.js",
            "timeout": 10,
            "statusMessage": "Checking AVmatrix index freshness..."
          }
        ]
      }
    ]
  }
}
